generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// =========================================================================
// Admin User Management — Multi-User Authentication with TOTP 2FA
// =========================================================================
// This section defines the database models for the multi-user admin system.
// The system supports:
//   - Multiple admin users with email/password authentication
//   - Mandatory TOTP-based two-factor authentication (Google/Microsoft Authenticator)
//   - One-time-use recovery codes as a 2FA backup
//   - Role-based access control (RBAC) with 5 permission tiers
//   - Full audit logging of all authentication and admin actions
// =========================================================================

/// An admin user who can log in to the admin console.
/// Each user must set up TOTP 2FA on first login (mustSetup2FA flag).
model AdminUser {
  id           String    @id @default(uuid())  // Unique identifier (UUID v4)
  email        String    @unique               // Login email — must be unique across all admins
  passwordHash String                          // bcrypt-hashed password (12 salt rounds)

  // Role determines what the user can do. See lib/permissions.ts for the full matrix.
  // Hierarchy: SUPER_ADMIN > ADMIN > OPERATOR > VIEWER_MANAGER > READ_ONLY
  role         String    @default("ADMIN")

  // TOTP (Time-based One-Time Password) fields for two-factor authentication.
  // The secret is encrypted with AES-256-GCM before storage (see lib/totp-crypto.ts).
  totpSecret   String?                         // Encrypted TOTP secret (null until 2FA is set up)
  totpEnabled  Boolean   @default(false)       // True after user completes 2FA setup
  mustSetup2FA Boolean   @default(true)        // Forces 2FA setup on next login

  isActive     Boolean   @default(true)        // Soft-delete: inactive users cannot log in
  lastLoginAt  DateTime?                       // Timestamp of most recent successful login
  createdById  String?                         // ID of the admin who created this user (nullable for seed)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Self-referential relation: tracks which admin created this user
  createdBy     AdminUser?    @relation("CreatedByAdmin", fields: [createdById], references: [id])
  createdUsers  AdminUser[]   @relation("CreatedByAdmin")
  recoveryCodes RecoveryCode[]  // One-time-use backup codes for 2FA
  auditLogs     AuditLog[]      // Actions performed by or related to this user

  @@index([email])  // Fast lookup for login
  @@index([role])   // Fast filtering by role
}

/// A one-time-use recovery code for 2FA backup.
/// When a user sets up 2FA, 10 recovery codes are generated. Each code can
/// only be used once (tracked by the usedAt timestamp). The plaintext code
/// is shown to the user once and only the bcrypt hash is stored in the DB.
model RecoveryCode {
  id        String    @id @default(uuid())
  userId    String                          // The admin user this code belongs to
  codeHash  String                          // bcrypt hash of the recovery code (plaintext never stored)
  usedAt    DateTime?                       // Null if unused; set to timestamp when consumed
  createdAt DateTime  @default(now())

  // Cascade delete: if the user is deleted, their recovery codes are too
  user AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])  // Fast lookup of all codes for a user during recovery login
}

/// Immutable audit trail for all authentication and admin actions.
/// Every login attempt (success/failure), 2FA setup, user creation, emergency
/// access, and role change is recorded here. The audit log is append-only and
/// viewable by Super Admins via the admin console UI.
model AuditLog {
  id        String   @id @default(uuid())
  userId    String?                         // The acting user (null for emergency/system actions)
  action    String                          // Action type: login, login_failed, 2fa_setup, user_created, etc.
  details   String?                         // Optional JSON string with extra context (e.g., target user email)
  ipAddress String                          // Client IP address for the request
  createdAt DateTime @default(now())        // When the action occurred

  // SetNull: if the user is deleted, the log entry persists but userId becomes null
  user AdminUser? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])    // Filter logs by user
  @@index([action])    // Filter logs by action type
  @@index([createdAt]) // Sort/paginate by time
}

// =========================================================================
// Creator & Channel Management — Multi-Tenant Content Creator System
// =========================================================================
// Creators are self-service users who own channels and manage their own
// events/tokens. They have a separate auth system from admins (different
// cookie, login page, and middleware). Admins retain full oversight and
// can suspend creators or channels at any time.
// =========================================================================

/// A content creator who owns one or more channels.
/// Creators register themselves, manage their own events/tokens/VODs,
/// and have a separate login system from administrators.
model Creator {
  id              String    @id @default(uuid())
  email           String    @unique             // Login identifier
  passwordHash    String                        // bcrypt-hashed password (12 salt rounds)
  displayName     String                        // Public-facing name

  isActive        Boolean   @default(true)      // Admin can suspend (blocks login + stream access)
  isEmailVerified Boolean   @default(false)     // For future email verification gating
  isPendingApproval Boolean @default(false)     // True when registered under 'approval' mode

  // Optional TOTP 2FA (same encryption as AdminUser — AES-256-GCM)
  totpSecret      String?                       // Encrypted TOTP secret
  totpEnabled     Boolean   @default(false)

  // Account lockout (brute-force protection)
  failedLoginAttempts Int       @default(0)     // Consecutive failed password attempts
  lockedUntil         DateTime?                 // Account locked until this time (null = not locked)

  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  channels Channel[]  // Channels owned by this creator

  @@index([email])
}

/// A content channel owned by a creator.
/// Channels are the namespace for events — each event belongs to at most
/// one channel. Channels can be independently suspended by admins.
model Channel {
  id          String   @id @default(uuid())
  creatorId   String                            // Owner (FK → Creator)
  name        String                            // Display name
  slug        String   @unique                  // URL-safe identifier (e.g., "tech-talks")
  description String?                           // Channel description
  logoUrl     String?                           // Channel branding image

  isActive    Boolean  @default(true)           // Admin can suspend
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  events  Event[]   // Events belonging to this channel

  @@index([creatorId])
  @@index([slug])
}

// --- Streaming Platform ---

model Event {
  id                String   @id @default(uuid())
  title             String
  description       String?
  streamType        String   @default("LIVE") // "LIVE" or "VOD"
  streamUrl         String?
  posterUrl         String?
  startsAt          DateTime
  endsAt            DateTime
  accessWindowHours Int      @default(48)
  isActive          Boolean  @default(true)
  isArchived        Boolean  @default(false)
  autoPurge         Boolean  @default(true)
  transcoderConfig  String?  // JSON: per-event transcoder overrides (null = use system defaults)
  playerConfig      String?  // JSON: per-event player overrides (null = use system defaults)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Channel ownership (nullable for backward compat — null = platform-level admin event)
  channelId   String?
  channel     Channel?  @relation(fields: [channelId], references: [id], onDelete: SetNull)

  // RTMP ingest authentication — per-event token + stream key hash
  rtmpStreamKeyHash String?    @unique      // Hashed stream key for RTMP publish (e.g., slug-based)
  rtmpToken         String?    @unique      // HMAC-based 24-char base62 token (encrypted at rest)
  rtmpTokenExpiresAt DateTime?              // Computed: event.endsAt (auto-renewed with event extension)

  tokens         Token[]
  rtmpSessions   RtmpSession[]
  rtmpPlayAllowlistEntries RtmpPlayAllowlistEntry[]
  upload         Upload?        // VOD upload for this event (null for live-only events)

  @@index([channelId])
}

model Token {
  id         String    @id @default(uuid())
  code       String    @unique
  eventId    String
  label      String?
  isRevoked  Boolean   @default(false)
  revokedAt  DateTime?
  redeemedAt DateTime?
  redeemedIp String?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())

  event          Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  activeSessions ActiveSession[]

  @@index([eventId])
  @@index([code])
  @@index([isRevoked])
}

model ActiveSession {
  id            String   @id @default(uuid())
  tokenId       String
  sessionId     String   @unique
  lastHeartbeat DateTime @default(now())
  clientIp      String
  userAgent     String?
  createdAt     DateTime @default(now())

  token Token @relation(fields: [tokenId], references: [id], onDelete: Cascade)

  @@index([tokenId])
  @@index([sessionId])
  @@index([lastHeartbeat])
}

/// Audit trail for active RTMP publishers per event.
/// Tracks single-publisher enforcement and publisher IP logging.
/// When an RTMP stream ends, endedAt is set (no hard delete for audit trail).
model RtmpSession {
  id            String   @id @default(uuid())
  eventId       String
  rtmpPublisherIp String  // Publisher IP address for audit trail
  startedAt     DateTime @default(now())
  endedAt       DateTime? // Null while streaming; set to now() on disconnect
  createdAt     DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([endedAt]) // Fast query for active sessions: WHERE endedAt IS NULL
}

/// Per-event allow list for direct RTMP PLAY access.
/// Single IPs are stored as canonical host CIDRs (/32 for IPv4, /128 for IPv6).
model RtmpPlayAllowlistEntry {
  id        String   @id @default(uuid())
  eventId   String
  cidr      String
  label     String?
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, cidr])
  @@index([eventId])
}

model SystemSettings {
  id                 String   @id @default("default")
  transcoderDefaults String   // JSON: system-wide transcoder defaults
  playerDefaults     String   // JSON: system-wide player defaults
  creatorRegistrationMode String @default("open") // "open" | "approval" | "disabled"

  // --- VOD Upload & Transcoding Settings ---
  maxUploadSizeBytes  BigInt   @default(5368709120)  // Max upload file size in bytes (default: 5 GB)
  enabledCodecs       String   @default("[\"h264\"]") // JSON array of enabled codec names for VOD transcoding
  vodRenditions       String   @default("{\"h264\":[{\"label\":\"1080p\",\"width\":1920,\"height\":1080,\"videoBitrate\":\"5000k\",\"audioBitrate\":\"192k\"},{\"label\":\"720p\",\"width\":1280,\"height\":720,\"videoBitrate\":\"2500k\",\"audioBitrate\":\"128k\"},{\"label\":\"480p\",\"width\":854,\"height\":480,\"videoBitrate\":\"1000k\",\"audioBitrate\":\"96k\"}]}") // JSON: per-codec VOD rendition ladders

  updatedAt          DateTime @updatedAt
}

// =========================================================================
// VOD Upload & Multi-Codec Transcoding
// =========================================================================
// When a creator uploads a video file for VOD, an Upload record tracks the
// file metadata and overall transcoding status. One TranscodeJob is created
// per enabled codec (e.g., H.264, AV1, VP9). Each job runs in its own
// ephemeral Azure Container Instance. The Upload is READY only when ALL
// of its TranscodeJobs reach COMPLETED status.
// =========================================================================

/// Tracks a video file uploaded by a creator/admin for VOD transcoding.
/// Each event can have at most one upload at a time. When a creator uploads
/// a video, this record tracks the file metadata and overall transcoding status.
/// Status lifecycle: UPLOADING → UPLOADED → TRANSCODING → READY (or FAILED at any step).
model Upload {
  id           String    @id @default(uuid())  // Unique identifier (UUID v4)
  eventId      String    @unique               // One upload per event (FK → Event)
  fileName     String                          // Original filename (e.g., "my-video.mp4")
  fileSize     BigInt                          // File size in bytes
  mimeType     String                          // MIME type (e.g., "video/mp4")
  blobPath     String                          // Path in Azure Blob: "uploads/{eventId}/{filename}"
  status       String    @default("UPLOADING") // UPLOADING | UPLOADED | TRANSCODING | READY | FAILED
  errorMessage String?                         // Human-readable error if status is FAILED
  duration     Float?                          // Video duration in seconds (set after transcoding)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relation: each upload belongs to exactly one event (cascade delete with the event)
  event         Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  // Relation: one TranscodeJob per codec (H.264, AV1, VP8, VP9)
  transcodeJobs TranscodeJob[]

  @@index([eventId])  // Fast lookup by event
  @@index([status])   // Fast filtering by upload status
}

/// Tracks a single codec transcoding job within an upload.
/// When a video is uploaded, one TranscodeJob is created per enabled codec
/// (e.g., H.264, AV1, VP9). Each job runs in its own Azure Container Apps Job.
/// The parent Upload is READY only when ALL jobs reach COMPLETED status.
model TranscodeJob {
  id            String    @id @default(uuid())  // Unique identifier (UUID v4)
  uploadId      String                           // FK → Upload
  codec         String                           // Codec name: "h264" | "av1" | "vp8" | "vp9"
  status        String    @default("PENDING")    // PENDING | RUNNING | COMPLETED | FAILED
  progress      Int?                             // Transcoding progress 0-100 (updated via callback)
  executionName String?                          // Azure Container Apps Job execution name (for tracking/cancellation)
  errorMessage  String?                          // Error details if FAILED
  startedAt     DateTime?                        // When the transcoder container started
  completedAt   DateTime?                        // When transcoding finished (success or failure)
  createdAt     DateTime  @default(now())

  // Relation: each job belongs to one upload (cascade delete with the upload)
  upload Upload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@index([uploadId])  // Fast lookup of all jobs for an upload
  @@index([status])    // Fast filtering by job status
  @@index([codec])     // Fast filtering by codec type
}

/// Shared configuration key-value store.
/// Stores secrets and settings (e.g., INTERNAL_API_KEY, PLAYBACK_SIGNING_SECRET)
/// so all services can read them from the DB instead of relying on env var sync.
/// Resolution order: environment variable → DB row → null (see lib/system-config.ts).
model SystemConfig {
  key       String   @id       // Config key (e.g., "INTERNAL_API_KEY")
  value     String             // Config value (plaintext — encrypt sensitive values at the app layer)
  updatedAt DateTime @updatedAt
}
