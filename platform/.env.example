# === Shared ===
PLAYBACK_SIGNING_SECRET=         # HMAC-SHA256 secret (min 32 chars, must match HLS server)
INTERNAL_API_KEY=                # Shared API key for internal endpoints (must match HLS server)

# === Platform App ===
DATABASE_URL=file:./dev.db       # SQLite for dev, PostgreSQL connection string for prod
ADMIN_PASSWORD_HASH=             # bcrypt hash of admin password (run: npm run hash-password)
HLS_SERVER_BASE_URL=http://localhost:4000  # Public URL of HLS Media Server
NEXT_PUBLIC_APP_NAME=StreamGate  # Branding name
SESSION_TIMEOUT_SECONDS=60       # Seconds before inactive viewing session is abandoned
