# === Shared ===
PLAYBACK_SIGNING_SECRET=         # HMAC-SHA256 secret (min 32 chars, must match both services)
INTERNAL_API_KEY=                # Shared API key for internal endpoints

# === Platform App ===
DATABASE_URL=file:./dev.db       # SQLite for dev, PostgreSQL connection string for prod
ADMIN_PASSWORD_HASH=             # bcrypt hash of admin password (legacy, kept for migration)
ADMIN_SESSION_SECRET=            # Secret for session encryption + TOTP encryption (min 32 chars)
HLS_SERVER_BASE_URL=http://localhost:4000  # Public URL of HLS Media Server
NEXT_PUBLIC_APP_NAME=StreamGate  # Branding name
SESSION_TIMEOUT_SECONDS=60       # Seconds before inactive viewing session is considered abandoned

# === Multi-User Auth (optional, set to enable) ===
INITIAL_ADMIN_EMAIL=             # Email for first Super Admin (used only when no admins exist)
INITIAL_ADMIN_PASSWORD=          # Password for first Super Admin (min 12 chars)
EMERGENCY_RECOVERY_PASSWORD=     # bcrypt hash of emergency recovery password (optional)

# === HLS Media Server ===
PLATFORM_APP_URL=http://localhost:3000  # Platform App URL for revocation polling
STREAM_ROOT=./streams            # Local filesystem path for stream files
UPSTREAM_ORIGIN=                 # Upstream HLS origin (blank = local only)
SEGMENT_CACHE_ROOT=              # Defaults to STREAM_ROOT/cache/
SEGMENT_CACHE_MAX_SIZE_GB=50
SEGMENT_CACHE_MAX_AGE_HOURS=72
REVOCATION_POLL_INTERVAL_MS=30000
CORS_ALLOWED_ORIGIN=http://localhost:3000
PORT=4000

# === VOD Upload & Transcoding (Azure only) ===
# These are required when deploying to Azure with VOD upload support.
# In local development, VOD transcoding is not available (requires Azure Container Apps Jobs).
AZURE_STORAGE_CONNECTION_STRING= # Azure Storage connection string for vod-uploads + hls-content containers
AZURE_SUBSCRIPTION_ID=           # Azure subscription ID (for launching transcoder jobs)
AZURE_RESOURCE_GROUP=            # Azure resource group containing the transcoder Container Apps Jobs
AZURE_MANAGED_IDENTITY_CLIENT_ID= # Client ID of the managed identity used to launch transcoder jobs
TRANSCODER_IMAGE_H264=           # ACR image for H.264 transcoder (e.g., myacr.azurecr.io/transcoder:v123)
TRANSCODER_IMAGE_AV1=            # ACR image for AV1 transcoder
TRANSCODER_IMAGE_VP9=            # ACR image for VP9 transcoder
TRANSCODER_IMAGE_VP8=            # ACR image for VP8 transcoder
